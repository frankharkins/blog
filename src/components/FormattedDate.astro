---
interface Props {
	date: Date;
}

const { date } = Astro.props;
---

<style>
    time {
        font-family: var(--main-font);
        font-size: .8rem;
        margin-top: 3rem;
    }
</style>
<time datetime={date.toISOString()}>
    { date.getDate() } / { date.toLocaleDateString('default', { month: 'long' }) } / { date.getFullYear() }
</time>
